{
    "name":  "appointment-scheduling-service",
    "version":  "1.0.0",
    "description":  "",
    "main":  "server.js",
    "scripts":  {
                    "dev":  "ts-node-dev -r tsconfig-paths/register --respawn --pretty --transpile-only src/server.ts",
                    "start":  "ts-node -r tsconfig-paths/register src/server.ts",
                    "build":  "tsc -p tsconfig.build.json \u0026\u0026 tsc-alias",
                    "migration:generate":  "typeorm-ts-node-commonjs migration:generate -d src/database/database.ts",
                    "migration:run":  "typeorm-ts-node-commonjs migration:run -d src/database/database.ts",
                    "migration:revert":  "typeorm-ts-node-commonjs migration:revert -d src/database/database.ts",
                    "test":  "jest",
                    "lint":  "eslint src/**/*.ts",
                    "format":  "prettier --write src/**/*.ts",
                    "prepare":  "husky"
                },
    "author":  "",
    "license":  "ISC",
    "dependencies":  {
                         "@decorators/express":  "^3.0.0",
                         "@types/swagger-jsdoc":  "^6.0.4",
                         "@types/swagger-ui-express":  "^4.1.8",
                         "bcrypt":  "^5.1.1",
                         "class-transformer":  "^0.5.1",
                         "class-validator":  "^0.14.0",
                         "dotenv":  "^16.3.1",
                         "express":  "^4.18.2",
                         "express-basic-auth":  "^1.2.1",
                         "express-rate-limit":  "^8.5.2",
                         "helmet":  "^8.2.0",
                         "ioredis":  "^5.11.1",
                         "moment":  "^2.29.4",
                         "moment-timezone":  "^0.5.43",
                         "opossum":  "^5.0.1",
                         "paseto":  "^3.1.4",
                         "pg":  "^8.11.3",
                         "prom-client":  "^15.1.3",
                         "reflect-metadata":  "^0.1.13",
                         "socket.io":  "^4.8.3",
                         "swagger-jsdoc":  "^6.3.0",
                         "swagger-ui-express":  "^5.0.1",
                         "typeorm":  "^0.3.17",
                         "uuid":  "^14.0.0",
                         "winston-daily-rotate-file":  "^5.0.0"
                     },
    "devDependencies":  {
                            "@testcontainers/postgresql":  "^12.0.3",
                            "@types/bcryptjs":  "^2.4.6",
                            "@types/express":  "^4.17.21",
