                            "@typescript-eslint/parser":  "^8.61.1",
                            "eslint":  "^10.5.0",
                            "husky":  "^9.1.7",
                            "jest":  "^30.4.2",
                            "jsonwebtoken":  "^9.0.2",
                            "lint-staged":  "^17.0.7",
                            "morgan":  "^1.10.0",
                            "nodemon":  "^3.0.1",
                            "prettier":  "^3.8.4",
                            "supertest":  "^7.2.2",
                            "testcontainers":  "^12.0.3",
                            "ts-jest":  "^29.4.11",
